      "args": ["--dev-version", "--flat"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": true,
      "env": {
        "PYTHONUNBUFFERED": "1"
      }
    },
    {
      "name": "Package AstrBot plugin (release)",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/scripts/package_plugin.py",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": true,
      "env": {
        "PYTHONUNBUFFERED": "1"
      }
    }
