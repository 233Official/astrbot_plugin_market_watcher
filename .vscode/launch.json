{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Package AstrBot plugin (test)",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/scripts/package_plugin.py",
      "args": ["--dev-version", "--test-label", "t2i"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": true,
      "env": {
        "PYTHONUNBUFFERED": "1"
      }
    },
    {
      "name": "Package AstrBot plugin (test flat legacy)",
      "type": "debugpy",
